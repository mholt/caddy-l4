{
	layer4 {
		:8080 {
			route {
				metrics
				proxy backend:8080
			}
		}
	}
}
----------
{
	"apps": {
		"layer4": {
			"servers": {
				"srv0": {
					"listen": [
						":8080"
					],
					"routes": [
						{
							"handle": [
								{
									"handler": "metrics"
								},
								{
									"handler": "proxy",
									"upstreams": [
										{
											"dial": [
												"backend:8080"
											]
										}
									]
								}
							]
						}
					]
				}
			}
		}
	}
}
